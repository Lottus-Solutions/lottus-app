# URL da API Lottus Mobile (Spring Boot).
#
# Em desenvolvimento o fallback automático já cobre os cenários comuns:
#   - iOS Simulator / web        -> http://localhost:8080
#   - Android Emulator           -> http://10.0.2.2:8080
#
# Para dispositivo físico (Expo Go), aponte para o IP da sua máquina na LAN
# (descubra com `ipconfig` no Windows ou `ifconfig` no macOS/Linux):
#
#   EXPO_PUBLIC_API_URL=http://192.168.0.10:8080
#
# Em produção, defina a URL pública do backend.
EXPO_PUBLIC_API_URL=http://localhost:8080
